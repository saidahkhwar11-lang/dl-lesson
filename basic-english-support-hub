function save(){ localStorage.setItem('basicEnglishHubYear', JSON.stringify(state)); }
function esc(s){ return String(s).replace(/[&<>"']/g, m => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m])); }
function showOnly(id){ ['landingView','teacherLoginView','studentLoginView','teacherView','studentView','rewardsView'].forEach(v=>$(v).classList.add('hidden')); $(id).classList.remove('hidden'); }
function progressKey(path,unit,activity){ return path+'|'+unit+'|'+activity; }
function totalFor(path){ return PATHS[path].units.reduce((n,u)=>n+u.activities.length,0); }
function doneFor(st){ return Object.keys(st.done||{}).filter(k=>k.startsWith(st.path+'|')).length; }
function unitDoneCount(st,ui){ const u=PATHS[st.path].units[ui]; return u.activities.filter(a=>st.done && st.done[progressKey(st.path,u.name,a.title)]).length; }
function isUnitUnlocked(st,ui){ if(ui===0) return true; return unitDoneCount(st,ui-1) === PATHS[st.path].units[ui-1].activities.length || (st.unlockedUnits||[]).includes(ui); }
function pathPct(st){ return Math.round((doneFor(st)/totalFor(st.path))*100); }
function shuffle(arr){ arr=[...arr]; for(let i=arr.length-1;i>0;i--){ const j=Math.floor(Math.random()*(i+1)); [arr[i],arr[j]]=[arr[j],arr[i]]; } return arr; }
function speakText(txt){ try{ speechSynthesis.cancel(); const u=new SpeechSynthesisUtterance(txt); u.rate=.82; speechSynthesis.speak(u); }catch(e){ alert('Audio is not available in this browser.'); } }

