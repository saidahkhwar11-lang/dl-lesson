  if(certs.length){
    certs.forEach(p=>{
      html+='<div class="cert" style="margin-top:14px"><h2>'+PATHS[p].label+' Certificate</h2><p>Awarded to</p><h1>'+esc(st.name)+'</h1><p>For successfully completing the '+PATHS[p].label+' Path.</p><button class="btn" onclick="window.print()">Print</button></div>';
    });
  }else{
    html+='<div class="empty">Complete all units in your path to unlock the certificate.</div>';
  }
  $('rewardsView').innerHTML=html;
  $('rewardHomeBtn').onclick=renderStudentHome; $('rewardLogoutBtn').onclick=logout;
}
function printCert(id){ currentStudent=id; state.current=id; save(); showRewards(); }

function resetData(){
  if(confirm('Reset all students and progress?')){
    localStorage.removeItem('basicEnglishHubYear');
    state={students:{},current:null}; selectedStudent=null; currentStudent=null;
    renderStudents(); $('teacherStudentProfile').className='empty'; $('teacherStudentProfile').innerHTML='Choose a student to view progress.';
  }
}

function bind(){
  $('teacherRole').onclick=showTeacherLogin; $('studentRole').onclick=showStudentLogin;
  $('teacherBackBtn').onclick=showLanding; $('studentBackBtn').onclick=showLanding;
  $('teacherLoginBtn').onclick=teacherLogin; $('studentLoginBtn').onclick=studentLogin;
  $('teacherPass').addEventListener('keydown',e=>{if(e.key==='Enter')teacherLogin();});
  $('loginId').addEventListener('keydown',e=>{if(e.key==='Enter')studentLogin();});
  $('teacherStudentsBtn').onclick=showTeacherStudents; $('teacherLibraryBtn').onclick=showTeacherLibrary;
  $('resetBtn').onclick=resetData; $('teacherLogoutBtn').onclick=logout; $('studentLogoutBtn').onclick=logout;
  $('addStudentBtn').onclick=addStudent; $('studentHomeBtn').onclick=renderStudentHome; $('studentRewardsBtn').onclick=showRewards;
  $('speakWelcomeBtn').onclick=()=>{ const st=state.students[currentStudent]; if(st) speakText('Hello '+st.name+'. Welcome to your English journey.'); };
  $('generateLpBtn').onclick=generateLessonPlan; $('printLpBtn').onclick=()=>window.print();
}
bind(); showOnly('landingView');
</script>
</body>
</html>
