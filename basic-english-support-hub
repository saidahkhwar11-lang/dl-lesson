function renderActivityStep(){
  const {unit, activity:a}=activeActivity;
  $('unitScreen').classList.add('hidden'); $('activityScreen').classList.remove('hidden');
  const steps=['1 Learn','2 Match','3 Practice','4 Use','5 Reward'];
  $('activityScreen').innerHTML='<button class="btn light" id="backUnitBtn">← Back to Unit</button>'+
    '<h2>'+unit.icon+' '+esc(unit.name)+' • '+esc(a.title)+'</h2>'+
    '<div class="stepDots">'+steps.map((s,i)=>'<span class="stepDot '+(i===activeStep?'active':'')+'">'+s+'</span>').join('')+'</div>'+
    '<div id="stepBody"></div><div class="menu" style="justify-content:center;margin-top:14px"><button class="btn light" id="prevStepBtn">Previous</button><button class="btn pink" id="nextStepBtn">Next</button></div>';
  $('backUnitBtn').onclick=()=>openUnit(activeActivity.unitIndex);
  $('prevStepBtn').onclick=()=>{ if(activeStep>0){ activeStep--; renderActivityStep(); } };
  $('prevStepBtn').disabled=activeStep===0;
  $('nextStepBtn').onclick=()=>{ if(activeStep<4){ activeStep++; renderActivityStep(); } else { completeActivity(); } };
  $('nextStepBtn').textContent=activeStep===4?'Complete Activity':'Next';
  const body=$('stepBody');
  if(activeStep===0) body.innerHTML=learnStep(a);
