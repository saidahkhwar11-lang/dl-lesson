function renderTeacherProfile(id){
  const st=state.students[id]; if(!st) return;
  st.completedPaths = st.completedPaths || [];
  st.certificates = st.certificates || [];
  const pct = pathPct(st);
  const next = nextPathKey(st.path);
  const ready = pct===100 && next;
  const finishedAll = pct===100 && !next;

  let html='<h2>'+esc(st.name)+'</h2>'+ 
    '<p><b>ID:</b> '+esc(st.id)+'</p>'+ 
    '<p><b>Current Path:</b> '+PATHS[st.path].label+' • '+PATHS[st.path].focus+'</p>'+
    '<div class="bar"><span style="width:'+pct+'%"></span></div>'+ 
    '<p><b>Stars in current path:</b> '+doneFor(st)+' / '+totalFor(st.path)+' <span class="pill '+(ready?'green':finishedAll?'gold':'')+'">'+(ready?'✅ Ready for Promotion':finishedAll?'🏆 Final Path Complete':'In Progress')+'</span></p>';

  html += '<div class="journeyBox"><h3>🎓 Learning Journey Record</h3>';
  if(st.completedPaths.length){
    html += '<p><b>Completed Paths:</b><br>'+st.completedPaths.map(p=>'<span class="pill gold">🏆 '+PATHS[p].label+'</span>').join(' ')+'</p>';
  }else{
    html += '<p><span class="pill">No completed paths yet</span></p>';
  }
  html += '<p><b>Current Path:</b> <span class="pill '+PATHS[st.path].colorClass+'">'+PATHS[st.path].label+'</span></p></div>';

  if(ready){
    html += '<div class="promoBox"><h3>🎉 Ready for Promotion</h3><p>'+esc(st.name)+' completed the '+PATHS[st.path].label+' Path. You can promote the student when you feel she is ready.</p><button class="btn green" id="promoteBtn">Promote to '+PATHS[next].label+'</button> <button class="btn light" id="extraPracticeBtn">Keep for Extra Practice</button></div>';
  }else if(!ready && next){
    html += '<div class="promoBox"><h3>🔒 Promotion Locked</h3><p>Promotion unlocks when the current path reaches 100%.</p><button class="btn light" disabled>Promote to '+PATHS[next].label+'</button></div>';
  }

  html += '<h3>Unit Progress</h3>';
  PATHS[st.path].units.forEach((u,i)=>{
    const done=unitDoneCount(st,i), total=u.activities.length;
    html += '<p>'+u.icon+' <b>'+esc(u.name)+':</b> '+done+'/'+total+' '+(isUnitUnlocked(st,i)?'<span class="pill green">Unlocked</span>':'<span class="pill red">Locked</span>')+'</p>';
  });
  html += '<div class="field"><label>Teacher Notes</label><textarea id="teacherNotes">'+esc(st.notes||'')+'</textarea></div>'+ 
    '<button class="btn green" id="saveNotesBtn">Save Notes</button> '+
    '<button class="btn" id="studentCertBtn">🏆 Certificates</button> '+
    '<button class="btn red" id="deleteStudentBtn">🗑 Delete Student</button>';
  $('teacherStudentProfile').className='';
  $('teacherStudentProfile').innerHTML=html;
  $('saveNotesBtn').onclick=()=>{ st.notes=$('teacherNotes').value; save(); alert('Notes saved.'); };
  $('studentCertBtn').onclick=()=>printCert(st.id);
  $('deleteStudentBtn').onclick=()=>deleteStudent(st.id);
  if($('promoteBtn')) $('promoteBtn').onclick=()=>promoteStudent(st.id);
  if($('extraPracticeBtn')) $('extraPracticeBtn').onclick=()=>alert('Student kept in current path for extra practice. Progress and certificate stay saved.');
}

function promoteStudent(id){
  const st=state.students[id]; if(!st) return;
  const next=nextPathKey(st.path);
  if(!next){ alert('This student is already on the final path.'); return; }
  if(pathPct(st)<100){ alert('Promotion is available after completing the current path.'); return; }
  if(!confirm('Promote '+st.name+' from '+PATHS[st.path].name+' to '+PATHS[next].name+'? Previous achievements will stay saved.')) return;
  st.completedPaths = st.completedPaths || [];
  st.certificates = st.certificates || [];
  if(!st.completedPaths.includes(st.path)) st.completedPaths.push(st.path);
  if(!st.certificates.includes(st.path)) st.certificates.push(st.path);
  st.path = next;
  st.unlockedUnits = [0];
  save();
  selectedStudent=id;
  renderStudents();
  renderTeacherProfile(id);
  alert('Student promoted to '+PATHS[next].name+' Path.');
}

function deleteStudent(id){
  if(confirm('Delete this student?')){
    delete state.students[id];
    if(state.current===id) state.current=null;
    selectedStudent=null; save(); renderStudents();
    $('teacherStudentProfile').className='empty';
    $('teacherStudentProfile').innerHTML='Choose a student to view progress.';
  }
}

