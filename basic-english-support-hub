<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Basic English Support Hub</title>
<style>
:root{
  --ink:#20314f;--muted:#64748b;--line:#dce7fb;--card:#ffffff;
  --pink:#ff8fc7;--sky:#7dd3fc;--mint:#86efac;--sun:#fde68a;--purple:#c4b5fd;
  --navy:#24335c;--green:#22c55e;--red:#ef4444;
  --shadow:0 16px 38px rgba(55,70,110,.14);
}
*{box-sizing:border-box}
body{
  margin:0;
  font-family:Arial, sans-serif;
  background:
    radial-gradient(circle at top left,rgba(255,143,199,.25),transparent 32%),
    radial-gradient(circle at top right,rgba(125,211,252,.28),transparent 35%),
    linear-gradient(135deg,#fff7ed,#eef7ff,#f7efff);
  color:var(--ink);
}
button,input,select,textarea{font-family:inherit;font-size:16px}
.hidden{display:none!important}
.app{max-width:1200px;margin:auto;padding:18px 18px 60px}
.hero{
  background:linear-gradient(135deg,#ff8fc7,#7dd3fc);
  color:#fff;border-radius:32px;padding:26px;box-shadow:var(--shadow);
  position:relative;overflow:hidden;
}
.hero:after{content:'🌈';position:absolute;right:20px;top:4px;font-size:95px;opacity:.26}
.hero h1{margin:0;font-size:36px}.hero p{margin:8px 0 0;font-weight:800}
.btn{
  border:0;border-radius:18px;padding:12px 18px;font-weight:900;cursor:pointer;
  background:var(--navy);color:white;box-shadow:0 8px 16px rgba(20,30,70,.18)
}
.btn.light{background:white;color:var(--navy)}.btn.pink{background:var(--pink)}.btn.green{background:var(--green)}.btn.red{background:var(--red)}
.btn.small{padding:8px 12px;border-radius:13px;font-size:14px}
.btn:disabled{opacity:.45;cursor:not-allowed;box-shadow:none}
.screen,.panel{
  background:rgba(255,255,255,.95);border:1px solid var(--line);
  border-radius:28px;padding:20px;box-shadow:var(--shadow);margin-top:18px
}
.center{max-width:760px;margin:22px auto;text-align:center}
.roleGrid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:18px;margin-top:18px}
.roleCard{background:white;border:1px solid var(--line);border-radius:30px;padding:30px;box-shadow:var(--shadow);cursor:pointer;transition:.18s}
.roleCard:hover{transform:translateY(-3px)}.roleCard .emoji{font-size:78px}.roleCard h2{font-size:28px;margin:10px 0}
.field{margin:12px 0;text-align:left}.field label{display:block;font-size:13px;font-weight:900;color:var(--muted);margin-bottom:5px}
.field input,.field select,.field textarea{width:100%;border:1px solid var(--line);border-radius:16px;padding:13px;background:#fff}
.field textarea{min-height:92px;resize:vertical}
.topBar{display:flex;gap:10px;justify-content:space-between;align-items:center;flex-wrap:wrap;margin-top:18px}
.menu{display:flex;gap:8px;flex-wrap:wrap}
.grid{display:grid;grid-template-columns:340px 1fr;gap:18px;margin-top:18px}
.studentCard,.unitCard,.activity{
  border:1px solid var(--line);background:#fff;border-radius:22px;padding:14px;margin:10px 0;box-shadow:0 8px 18px rgba(50,70,110,.08)
}
.studentCard{cursor:pointer}.studentCard.active{outline:4px solid #bfdbfe}.studentCard b{font-size:18px}
.pill{display:inline-flex;align-items:center;gap:6px;border-radius:999px;padding:6px 10px;font-size:13px;font-weight:900;background:#eef2ff;color:#39476c;margin:4px 5px 0 0}
.pill.green{background:#dcfce7}.pill.blue{background:#e0f2fe}.pill.purple{background:#ede9fe}.pill.gold{background:#fef3c7}.pill.red{background:#fee2e2}
.bar{height:15px;background:#e8eefc;border-radius:999px;overflow:hidden}.bar span{display:block;height:100%;background:linear-gradient(90deg,#ff8fc7,#7dd3fc,#86efac);width:0%}
.pathHero{display:grid;grid-template-columns:1fr auto;gap:15px;align-items:center}
.units{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:14px}
.unitCard.locked{opacity:.55}.unitCard h3{margin:4px 0 8px;font-size:22px}
.activities{display:grid;grid-template-columns:repeat(auto-fit,minmax(190px,1fr));gap:12px;margin-top:12px}
.activity{margin:0}.activity .icon{font-size:43px}.activity h4{margin:6px 0}.doneTag{color:#16a34a;font-weight:900}.notDone{color:#64748b;font-weight:800}
.stepDots{display:flex;gap:8px;justify-content:center;flex-wrap:wrap;margin:14px 0}
.stepDot{border-radius:999px;padding:8px 12px;background:#eef2ff;font-weight:900;color:#475569}.stepDot.active{background:var(--navy);color:white}
.bigQuestion{text-align:center}.bigEmoji{font-size:110px;line-height:1.1}.word{font-size:50px;font-weight:900;margin:8px 0;color:#24335c}
.answers{display:grid;gap:12px;max-width:560px;margin:18px auto}
.answerBtn{border:0;border-radius:24px;padding:18px;background:#e0f2fe;font-size:22px;font-weight:900;cursor:pointer}
.answerBtn:hover{background:#bae6fd}
.matchGrid{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:12px;max-width:700px;margin:18px auto}
.matchCard{background:#fff7ed;border:2px solid #fed7aa;border-radius:24px;padding:20px;font-size:22px;font-weight:900;cursor:pointer}
.success{background:#dcfce7;border-radius:22px;padding:16px;text-align:center;font-size:24px;font-weight:900}.wrong{background:#fee2e2;border-radius:22px;padding:16px;text-align:center;font-size:22px;font-weight:900}
.cert{border:8px solid #fde68a;border-radius:28px;padding:34px;text-align:center;background:linear-gradient(135deg,#fff,#fff7ed)}
.cert h2{font-size:36px;color:#b45309}
.empty{text-align:center;color:var(--muted);padding:28px;border:2px dashed var(--line);border-radius:22px;background:#fbfdff}
.msg{font-weight:900;color:#ef4444}
.promoBox{background:linear-gradient(135deg,#ecfccb,#e0f2fe);border:1px solid var(--line);border-radius:22px;padding:16px;margin:14px 0}
.journeyBox{background:#f8fafc;border:1px solid var(--line);border-radius:18px;padding:12px;margin:10px 0}
.lpBox{background:#fff;border:1px solid var(--line);border-radius:22px;padding:20px;line-height:1.55}
.lpBox h2,.lpBox h3{margin-bottom:6px}
.lpControls{display:flex;gap:8px;flex-wrap:wrap;margin:10px 0}
table{width:100%;border-collapse:collapse;background:white;border-radius:18px;overflow:hidden}
td,th{border:1px solid var(--line);padding:10px;text-align:left}
@media print{
  body{background:white}.hero,.topBar,.menu,.grid aside,.lpControls,.btn:not(.printKeep){display:none!important}
  .app{max-width:none;padding:0}.screen,.panel,.lpBox{box-shadow:none;border:0;margin:0}
}
@media(max-width:850px){
  .grid,.roleGrid,.pathHero{grid-template-columns:1fr}.hero h1{font-size:28px}.app{padding:12px}.roleCard .emoji{font-size:60px}.word{font-size:40px}.bigEmoji{font-size:90px}
}
</style>
</head>
<body>
<div class="app">
  <section class="hero">
    <h1>Basic English Support Hub</h1>
    <p>Learn • Practice • Achieve</p>
  </section>

  <section id="landingView" class="screen center">
    <h2>🌈 Welcome</h2>
    <p>Choose your role to continue.</p>
    <div class="roleGrid">
      <div class="roleCard" id="teacherRole"><div class="emoji">👩‍🏫</div><h2>Teacher Login</h2><p>Manage students, lesson plans, notes, and progress.</p></div>
      <div class="roleCard" id="studentRole"><div class="emoji">👤</div><h2>Student Login</h2><p>Start your English journey.</p></div>
    </div>
  </section>

  <section id="teacherLoginView" class="screen center hidden">
    <h2>👩‍🏫 Teacher Login</h2>
    <div class="field"><label>Password</label><input id="teacherPass" type="password" placeholder="Teacher password"></div>
    <button class="btn green" id="teacherLoginBtn">Login</button>
    <button class="btn light" id="teacherBackBtn">Back</button>
    <p id="teacherMsg" class="msg"></p>
  </section>

  <section id="studentLoginView" class="screen center hidden">
    <h2>👤 Student Login</h2>
    <div class="field"><label>Student ID</label><input id="loginId" placeholder="Write student ID"></div>
    <button class="btn pink" id="studentLoginBtn">Start Learning</button>
    <button class="btn light" id="studentBackBtn">Back</button>
    <p id="loginMsg" class="msg"></p>
  </section>

  <section id="teacherView" class="hidden">
    <div class="topBar">
      <h2>👩‍🏫 Teacher Dashboard</h2>
      <div class="menu">
        <button class="btn light" id="teacherStudentsBtn">Students</button>
        <button class="btn light" id="teacherLibraryBtn">Lesson Plans</button>
        <button class="btn light" id="resetBtn">Reset Data</button>
        <button class="btn red" id="teacherLogoutBtn">Logout</button>
      </div>
    </div>

    <div id="teacherStudentsPanel" class="grid">
      <aside class="panel">
        <h2>➕ Add Student</h2>
        <div class="field"><label>Student Name</label><input id="sName" placeholder="Example: Ahmed"></div>
        <div class="field"><label>Student ID</label><input id="sId" placeholder="Example: 1001"></div>
        <div class="field"><label>Assign Path</label>
          <select id="sPath">
            <option value="explorer">🟢 Explorer</option>
            <option value="adventurer">🔵 Adventurer</option>
            <option value="champion">🟣 Champion</option>
          </select>
        </div>
        <button class="btn green" id="addStudentBtn">Save Student</button>
        <hr style="border:0;border-top:1px solid var(--line);margin:18px 0">
        <h3>Students</h3>
        <div id="studentsList"></div>
      </aside>
      <main class="panel"><div id="teacherStudentProfile" class="empty">Choose a student to view progress.</div></main>
    </div>

    <div id="teacherLibraryPanel" class="panel hidden">
      <h2>📋 Lesson Plan Generator</h2>
      <p>Choose any activity path and generate a printable lesson plan.</p>
      <div class="field"><label>Path</label><select id="lpPath"></select></div>
      <div class="field"><label>Unit</label><select id="lpUnit"></select></div>
      <div class="field"><label>Activity</label><select id="lpActivity"></select></div>
      <div class="lpControls">
        <button class="btn green" id="generateLpBtn">Generate Lesson Plan</button>
        <button class="btn light" id="printLpBtn">Print</button>
      </div>
      <div id="lessonPlanBox" class="lpBox empty">Choose an activity and click Generate Lesson Plan.</div>
    </div>
  </section>

  <section id="studentView" class="hidden">
    <div class="topBar">
      <h2 id="helloStudent">Hello</h2>
      <div class="menu">
        <button class="btn light" id="studentHomeBtn">Home</button>
        <button class="btn light" id="studentRewardsBtn">Rewards</button>
        <button class="btn red" id="studentLogoutBtn">Logout</button>
      </div>
    </div>
    <div id="studentHomeScreen">
      <div class="screen">
        <div class="pathHero">
          <div>
            <div id="studentStats"></div>
            <div class="bar" style="margin-top:12px"><span id="studentBar"></span></div>
          </div>
          <button class="btn light" id="speakWelcomeBtn">🔊 Listen</button>
        </div>
      </div>
      <div class="screen">
        <h2 id="pathTitle">My Path</h2>
        <div id="units" class="units"></div>
      </div>
    </div>
    <div id="unitScreen" class="screen hidden"></div>
    <div id="activityScreen" class="screen hidden"></div>
  </section>

  <section id="rewardsView" class="screen hidden"></section>
</div>

